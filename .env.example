# Resummme — Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — the editor works without them.
# Only AI features and production PDF export require keys.

# ─── AI Features (Google Gemini) ─────────────────────────────────────────────
# Powers "Extract from PDF", "Improve with AI", and "Analyze job description".
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=

# Optional: override the default model
GEMINI_MODEL=gemini-2.0-flash

# ─── PDF Export ──────────────────────────────────────────────────────────────
# "auto" (default) | "puppeteer" | "cloudflare-browser-run"
# In development, "auto" uses local Puppeteer — no extra setup needed.
PDF_EXPORT_PROVIDER=auto

# Required when PDF_EXPORT_PROVIDER=cloudflare-browser-run
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BROWSER_RUN_API_TOKEN=
# Optional: session keep-alive in milliseconds
CLOUDFLARE_BROWSER_RUN_KEEP_ALIVE_MS=60000

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call /api/export-pdf cross-origin.
# Same-origin requests are always allowed. Leave blank unless needed.
PDF_EXPORT_TRUSTED_ORIGINS=
