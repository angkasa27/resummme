# Resume Editor Environment Variables
# Copy this file to .env.local and fill in the values

# PDF Export - Comma-separated list of allowed origins for PDF generation
# Example: https://example.com,https://app.example.com
PDF_EXPORT_TRUSTED_ORIGINS=

# Gemini PDF import
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: Additional trust configurations
# (Vercel deployments are automatically allowed)
