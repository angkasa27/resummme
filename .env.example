# Resume Editor Environment Variables
# Copy this file to .env.local and fill in the values

# PDF Export provider
# auto: local Puppeteer in development, Cloudflare Browser Run in production if configured
# local-puppeteer: always use local Puppeteer
# cloudflare-browser-run: always use Cloudflare Browser Run
PDF_EXPORT_PROVIDER=auto

# PDF Export - Cloudflare Browser Run configuration
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BROWSER_RUN_API_TOKEN=
# Optional: Browser Run session keep-alive in milliseconds
CLOUDFLARE_BROWSER_RUN_KEEP_ALIVE_MS=60000

# PDF Export - Comma-separated list of additional trusted origins for cross-origin PDF requests
# Example: https://example.com,https://app.example.com
PDF_EXPORT_TRUSTED_ORIGINS=

# Gemini PDF import
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Same-origin requests are automatically allowed.
